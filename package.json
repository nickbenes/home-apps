{
  "name": "home-apps",
  "version": "1.0.0",
  "description": "Home Apps \u2014 finance, todos, calendar, food",
  "main": "server.js",
  "scripts": {
    "start": "tsx projects/todos/backend/server.ts",
    "build": "node build.js",
    "dev": "npm run build && npm start",
    "watch": "node build.js --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPatterns='unit|api.test' --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",

    "todos:dev": "tsx projects/todos/backend/server.ts",
    "todos:db:migrate": "tsx projects/todos/backend/migrate.ts",
    "todos:db:reset": "node -e \"['todos.db','todos.db-shm','todos.db-wal'].forEach(f=>require('fs').rmSync('projects/todos/data/'+f,{force:true}))\" && npm run todos:db:migrate",
    "calendar:dev": "tsx projects/calendar/backend/server.ts",

    "finance:dev": "tsx projects/finance/backend/server.ts",
    "finance:build": "npm run build && npm run finance:css",
    "finance:css": "tailwindcss -i projects/finance/frontend/index.css -o public/finance/bundle.css",
    "finance:css:watch": "tailwindcss -i projects/finance/frontend/index.css -o public/finance/bundle.css --watch",
    "finance:test:e2e": "playwright test --config=playwright.finance.config.ts",
    "finance:db:migrate": "tsx projects/finance/backend/migrate.ts",
    "finance:db:import": "tsx projects/finance/backend/import-seed.ts",
    "finance:db:import-example": "SEED_EXAMPLE=1 tsx projects/finance/backend/import-seed.ts",
    "finance:db:import-transactions": "tsx projects/finance/backend/import-transactions.ts",
    "finance:db:export": "tsx projects/finance/backend/export-seed.ts",
    "finance:db:tag": "tsx projects/finance/backend/tag-from-csv.ts",
    "finance:db:reset": "node -e \"['finance.db','finance.db-shm','finance.db-wal'].forEach(f=>require('fs').rmSync('projects/finance/data/'+f,{force:true}))\" && npm run finance:db:migrate && npm run finance:db:import",

    "food:dev": "tsx projects/food/backend/server.ts",
    "food:build": "npm run build && npm run food:css",
    "food:css": "tailwindcss -i projects/food/frontend/index.css -o public/food/bundle.css",
    "food:css:watch": "tailwindcss -i projects/food/frontend/index.css -o public/food/bundle.css --watch",
    "food:db:migrate": "tsx projects/food/backend/migrate.ts",
    "food:db:import": "tsx projects/food/backend/import-seed.ts",
    "food:db:import-example": "SEED_EXAMPLE=1 tsx projects/food/backend/import-seed.ts",
    "food:db:export": "tsx projects/food/backend/export-seed.ts",
    "food:db:reset": "node -e \"['food.db','food.db-shm','food.db-wal'].forEach(f=>require('fs').rmSync('projects/food/data/'+f,{force:true}))\" && npm run food:db:migrate && npm run food:db:import",

    "db:reset": "npm run finance:db:reset && npm run food:db:reset",
    "db:import": "npm run finance:db:import && npm run food:db:import",

    "db:seed": "tsx projects/finance/backend/seed.ts",
    "db:tag": "npm run finance:db:tag",
    "db:import-transactions": "tsx projects/finance/backend/import-transactions.ts"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "csv-parse": "^6.2.1",
    "express": "^4.18.2",
    "lucide-react": "^0.552.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "babel-jest": "^30.4.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-tools": "^15.18.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "react-router-dom": "^7.15.1",
    "supertest": "^6.3.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
