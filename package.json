{
  "name": "express-hello-world",
  "version": "1.0.0",
  "description": "Simple Express server with hello world endpoint",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node build.js",
    "dev": "npm run build && npm start",
    "watch": "node build.js --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPatterns='unit|api.test' --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",
    "deploy:bills": "npx firebase-tools deploy --only hosting",
    "smoke:deploy": "bash ./scripts/smoke/deploy-smoke.sh",
    "smoke:e2e": "npx playwright test projects/bills/test/e2e/bills.spec.ts --reporter=list",
    "db:migrate": "tsx projects/benes-finance/backend/migrate.ts",
    "db:seed": "tsx projects/benes-finance/backend/seed.ts",
    "db:reset": "node -e \"require('fs').rmSync('projects/benes-finance/data/benes-finance.db', {force:true})\" && npm run db:migrate && npm run db:seed",
    "db:import": "tsx projects/benes-finance/backend/import-transactions.ts",
    "finance:css": "tailwindcss -i projects/benes-finance/frontend/index.css -o public/benes-finance/bundle.css",
    "finance:css:watch": "tailwindcss -i projects/benes-finance/frontend/index.css -o public/benes-finance/bundle.css --watch",
    "finance:build": "npm run build && npm run finance:css",
    "finance:dev": "tsx projects/benes-finance/backend/server.ts",
    "finance:test:e2e": "playwright test --config=playwright.finance.config.ts"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "csv-parse": "^6.2.1",
    "express": "^4.18.2",
    "lucide-react": "^0.552.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "babel-jest": "^30.4.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-tools": "^15.18.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "react-router-dom": "^7.15.1",
    "supertest": "^6.3.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
